// src/components/chat/ChatWindow.js
import React, { useState, useEffect, useRef, useCallback } from "react";
import styled from "styled-components";
import {
  collection,
  query,
  orderBy,
  onSnapshot,
  addDoc,
  deleteDoc,
  doc,
  serverTimestamp,
  limit,
  startAfter,
  getDocs,
} from "firebase/firestore";
import { db } from "../../firebase/firebase";
import ContentLoader from "react-content-loader";
import formatChatTime from "../../utils/formatTime"; // 시간 포맷 유틸
import { sendImageMessage } from "../../services/chatService"; // 이미지 전송 함수

// Styled-components
const ChatContainer = styled.div`
  display: flex;
  flex-direction: column;
  max-width: 600px;
  height: 80vh;
  margin: 20px auto;
  background: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
`;
const MessagesContainer = styled.div`
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  border-bottom: 1px solid #eee;
`;
const MessageBubble = styled.div`
  max-width: 70%;
  margin-bottom: 12px;
  padding: 10px 14px;
  border-radius: 16px;
  background: ${(props) => (props.isOwn ? "#d1e7dd" : "#e2e3e5")};
  align-self: ${(props) => (props.isOwn ? "flex-end" : "flex-start")};
  position: relative;
`;
const SenderText = styled.strong`
  display: block;
  margin-bottom: 4px;
  color: #333;
`;
const TimeText = styled.span`
  font-size: 0.75em;
  color: #666;
  margin-left: 8px;
`;
const DeleteButton = styled.button`
  position: absolute;
  top: 4px;
  right: 4px;
  background: transparent;
  border: none;
  color: #888;
  cursor: pointer;
  font-size: 0.8em;
  &:hover {
    color: #e74c3c;
  }
`;
const InputContainer = styled.div`
  display: flex;
  flex-direction: column;
  padding: 12px;
`;
const MessageInputRow = styled.div`
  display: flex;
  margin-bottom: 8px;
`;
const MessageInput = styled.input`
  flex: 1;
  padding: 10px;
  border: 1px solid #ccc;
  border-radius: 4px;
  margin-right: 8px;
`;
const SendButtonStyled = styled.button`
  padding: 10px 16px;
  background: #007bff;
  color: #fff;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  &:disabled {
    background: #aaa;
    cursor: not-allowed;
  }
`;
const FileInput = styled.input`
  margin-bottom: 8px;
`;
const PreviewImage = styled.img`
  max-width: 100px;
  max-height: 100px;
  object-fit: cover;
  border-radius: 6px;
  margin-bottom: 8px;
`;
const LoaderWrapper = styled.div`
  padding: 20px;
  text-align: center;
`;

export default function ChatWindow({ chatId, userName }) {
  const [messages, setMessages] = useState([]);
  const [loading, setLoading] = useState(true);
  const [sending, setSending] = useState(false);
  const [hasMore, setHasMore] = useState(true);
  const [lastDoc, setLastDoc] = useState(null);
  const [imageFile, setImageFile] = useState(null);
  const [previewUrl, setPreviewUrl] = useState(null);

  const messagesEndRef = useRef(null);
  const PAGE_SIZE = 30;

  // 페이지네이션 로드
  const loadMessages = useCallback(async () => {
    try {
      const messagesRef = collection(db, "chats", chatId, "messages");
      let q = query(
        messagesRef,
        orderBy("timestamp", "desc"),
        limit(PAGE_SIZE)
      );
      if (lastDoc) {
        q = query(
          messagesRef,
          orderBy("timestamp", "desc"),
          startAfter(lastDoc),
          limit(PAGE_SIZE)
        );
      }
      const snapshot = await getDocs(q);
      const docs = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));
      if (docs.length < PAGE_SIZE) {
        setHasMore(false);
      }
      if (docs.length) {
        setLastDoc(snapshot.docs[snapshot.docs.length - 1]);
      }
      setMessages((prev) => [...docs.reverse(), ...prev]);
    } catch (err) {
      console.error("페이징 메시지 로드 오류:", err);
    } finally {
      setLoading(false);
    }
  }, [chatId, lastDoc]);

  useEffect(() => {
    loadMessages();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [loadMessages]);

  // 실시간 구독
  useEffect(() => {
    const messagesRef = collection(db, "chats", chatId, "messages");
    const qLive = query(messagesRef, orderBy("timestamp", "asc"));
    const unsub = onSnapshot(
      qLive,
      (snap) => {
        const docs = snap.docs.map((d) => ({ id: d.id, ...d.data() }));
        setMessages(docs);
        setLoading(false);
        messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
      },
      (err) => {
        console.error("실시간 메시지 구독 오류:", err);
      }
    );
    return () => unsub();
  }, [chatId]);

  // 텍스트 메시지 전송
  const handleSend = async () => {
    const inputEl = document.getElementById("cw-input");
    const text = inputEl.value;
    if (!text.trim()) return;
    setSending(true);
    try {
      await addDoc(collection(db, "chats", chatId, "messages"), {
        sender: userName,
        text,
        timestamp: serverTimestamp(),
        readBy: [userName],
      });
      inputEl.value = "";
    } catch (e) {
      console.error("메시지 전송 실패:", e);
      alert("메시지 전송에 실패했습니다.");
    } finally {
      setSending(false);
    }
  };

  // 이미지 파일 선택 시 미리보기 설정
  const handleFileChange = (e) => {
    const file = e.target.files[0];
    if (file) {
      setImageFile(file);
      setPreviewUrl(URL.createObjectURL(file));
    }
  };

  // 이미지 메시지 전송
  const handleSendImage = async () => {
    if (!imageFile) return;
    setSending(true);
    try {
      await sendImageMessage(chatId, userName, imageFile);
      // 전송 후 상태 초기화
      setImageFile(null);
      setPreviewUrl(null);
    } catch (e) {
      console.error("이미지 전송 실패:", e);
      alert("이미지 전송에 실패했습니다.");
    } finally {
      setSending(false);
    }
  };

  // 메시지 삭제
  const handleDelete = async (msgId) => {
    if (!window.confirm("정말 메시지를 삭제하시겠습니까?")) return;
    try {
      await deleteDoc(doc(db, "chats", chatId, "messages", msgId));
    } catch (e) {
      console.error("삭제 실패:", e);
      alert("메시지 삭제에 실패했습니다.");
    }
  };

  // 초기 로딩 화면
  if (loading) {
    return (
      <LoaderWrapper>
        <ContentLoader
          height={80}
          width={400}
          backgroundColor="#f3f3f3"
          foregroundColor="#ecebeb"
        >
          <rect x="0" y="10" rx="4" ry="4" width="400" height="20" />
          <rect x="0" y="40" rx="4" ry="4" width="300" height="20" />
        </ContentLoader>
      </LoaderWrapper>
    );
  }

  return (
    <ChatContainer>
      {/* 과거 메시지 로드 버튼 */}
      {hasMore && (
        <button onClick={loadMessages} disabled={loading}>
          더 불러오기
        </button>
      )}

      {/* 메시지 목록 */}
      <MessagesContainer>
        {messages.map((msg) => {
          // Firestore Timestamp → Date 객체로 변환
          const dateObj =
            typeof msg.timestamp.toDate === "function"
              ? msg.timestamp.toDate()
              : msg.timestamp;
          // formatChatTime을 사용하여 시간 문자열 얻기
          const timeLabel = formatChatTime(dateObj);

          return (
            <MessageBubble key={msg.id} isOwn={msg.sender === userName}>
              <SenderText>
                {msg.sender}
                <TimeText>{timeLabel}</TimeText>
              </SenderText>

              {/* 텍스트 메시지 or 이미지 메시지 구분 렌더링 */}
              {msg.text && <div>{msg.text}</div>}
              {msg.imageUrl && (
                <img
                  src={msg.imageUrl}
                  alt="이미지"
                  style={{
                    maxWidth: "200px",
                    maxHeight: "200px",
                    borderRadius: "6px",
                    marginTop: "8px",
                  }}
                />
              )}

              <DeleteButton onClick={() => handleDelete(msg.id)}>
                삭제
              </DeleteButton>
            </MessageBubble>
          );
        })}
        <div ref={messagesEndRef} />
      </MessagesContainer>

      {/* 입력창 영역 */}
      <InputContainer>
        {/* 텍스트 입력 + 전송 버튼 */}
        <MessageInputRow>
          <MessageInput
            id="cw-input"
            type="text"
            placeholder="메시지 입력..."
            disabled={sending}
            onKeyDown={(e) => e.key === "Enter" && handleSend()}
          />
          <SendButtonStyled onClick={handleSend} disabled={sending}>
            {sending ? "전송 중…" : "전송"}
          </SendButtonStyled>
        </MessageInputRow>

        {/* 이미지 선택 및 미리보기 */}
        <FileInput
          type="file"
          accept="image/*"
          onChange={handleFileChange}
          disabled={sending}
        />
        {previewUrl && (
          <>
            <PreviewImage src={previewUrl} alt="미리보기" />
            <SendButtonStyled onClick={handleSendImage} disabled={sending}>
              {sending ? "이미지 전송 중…" : "이미지 전송"}
            </SendButtonStyled>
          </>
        )}
      </InputContainer>
    </ChatContainer>
  );
}
