rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ───────── 공통 헬퍼 ───────── */
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() &&
             (request.auth.token.admin == true || request.auth.token.superAdmin == true);
    }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // 기존 값이 있으면 변경/삭제 불가(닉네임 불변)
    function fieldUnchanged(field) {
      return !(field in resource.data)
             || (field in request.resource.data
                 && request.resource.data[field] == resource.data[field]);
    }

    /* 사용자가 users/{uid} 문서에서 bonus 전체를 바꾸지 못하게 차단 */
    function noClientBonusMutation() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['bonus']);
    }

    /* ───────── appConfig ───────── */
    match /appConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* 예약 슬롯(사용자는 삭제 없는 업데이트만) */
    match /appConfig/reservedSlots {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if signedIn() &&
        request.resource.data.diff(resource.data).removedKeys().size() == 0;
    }

    /* ───────── products ───────── */
    match /products/{id} {
      allow read: if true;

      allow create: if signedIn() &&
        request.resource.data.sellerId == request.auth.uid;

      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.sellerId == request.auth.uid);

      // 좋아요 토글만 별도 허용
      allow update: if signedIn() && isLikeToggle();

      function isLikeToggle() {
        let beforeLiked  = (resource.data.likedBy is list) ? resource.data.likedBy : [];
        let beforeCount  = (resource.data.likesCount is number) ? resource.data.likesCount : 0;
        let afterLiked   = (request.resource.data.likedBy is list) ? request.resource.data.likedBy : [];
        let afterCount   = (request.resource.data.likesCount is number) ? request.resource.data.likesCount : 0;

        let keysOk = request.resource.data.diff(resource.data)
                      .changedKeys().hasOnly(['likedBy','likesCount']);

        let like =
          !(request.auth.uid in beforeLiked) &&
           (request.auth.uid in afterLiked)  &&
           (afterLiked.size() == beforeLiked.size() + 1) &&
           (afterCount == beforeCount + 1);

        let unlike =
           (request.auth.uid in beforeLiked) &&
          !(request.auth.uid in afterLiked)  &&
           (afterLiked.size() == beforeLiked.size() - 1) &&
           (afterCount == beforeCount - 1);

        return keysOk && (like || unlike);
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if signedIn();
        allow update, delete: if isAdmin();
      }
    }

    /* ───────── boards(두 경로 유지) ───────── */
    match /boards/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;

      // 작성자 업데이트: 답변 관련 필드 금지 + status는 '값을 바꾸지 않는 경우'만 허용
      allow update: if signedIn() && resource.data.authorId == request.auth.uid
        && !('answer' in request.resource.data)
        && !('answeredAt' in request.resource.data)
        && !('answeredBy' in request.resource.data)
        && (
          !('status' in request.resource.data) ||
          request.resource.data.status == resource.data.status
        );

      // 관리자 업데이트: 제한 없이 허용(답변 등록/수정 포함)
      allow update: if isAdmin();

      allow delete: if isAdmin() || (signedIn() && resource.data.authorId == request.auth.uid);
    }

    match /board/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;

      // 작성자 업데이트(단일 컬렉션명도 동일 정책)
      allow update: if signedIn() && resource.data.authorId == request.auth.uid
        && !('answer' in request.resource.data)
        && !('answeredAt' in request.resource.data)
        && !('answeredBy' in request.resource.data)
        && (
          !('status' in request.resource.data) ||
          request.resource.data.status == resource.data.status
        );

      allow update: if isAdmin();

      allow delete: if isAdmin() || (signedIn() && resource.data.authorId == request.auth.uid);
    }

    /* ───────── users (fcmTokens 포함) ───────── */
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);

      // ⚠️ 클라이언트는 bonus 수정 금지 (관리자만 가능)
      allow update: if isAdmin() || (isOwner(uid) && noClientBonusMutation());
      allow delete: if isAdmin();

      /* users/{uid}/ledger — 서버(Admin)만 기록 */
      match /ledger/{docId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }

      /* users/{uid}/promotions — 서버(Admin/Functions)만 write */
      match /promotions/{promoId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin(); // onCall/Triggers는 Admin 권한으로 진행
      }
    }

    /* 즐겨찾기 */
    match /users/{uid}/favorites/{productId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    /* 차단 목록 */
    match /users/{uid}/blocks/{otherUid} {
      allow read, create, update, delete: if isOwner(uid) || isAdmin();
    }

    /* ───────── profiles ───────── */
    match /profiles/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) || isAdmin();
      allow update: if (isOwner(uid) || isAdmin())
        && request.resource.data.keys().hasOnly([
          'displayName','nickname','photoURL','sellerRatingAvg','sellerRatingCount','nicknameLower'
        ])
        && (!('sellerRatingAvg' in request.resource.data)
            || (request.resource.data.sellerRatingAvg is number
                && request.resource.data.sellerRatingAvg >= 0
                && request.resource.data.sellerRatingAvg <= 5))
        && (!('sellerRatingCount' in request.resource.data)
            || (request.resource.data.sellerRatingCount is number
                && request.resource.data.sellerRatingCount >= 0))
        // 닉네임/닉네임 소문자 불변 (관리자는 예외)
        && (isAdmin() || fieldUnchanged('nickname'))
        && (isAdmin() || fieldUnchanged('nicknameLower'));
      allow delete: if isAdmin();
    }

    /* ───────── chats & messages ───────── */
    match /chats/{chatId} {
      function chatData(chatId) {
        return get(/databases/$(database)/documents/chats/$(chatId)).data;
      }
      function isChatParticipant(chatId) {
        let c = chatData(chatId);
        return (
          (c.participants is list && request.auth.uid in c.participants) ||
          (c.participantsMap is map && c.participantsMap[request.auth.uid] == true)
        );
      }
      function isNewChatParticipant() {
        return (
          (request.resource.data.participants is list && request.auth.uid in request.resource.data.participants) ||
          (request.resource.data.participantsMap is map && request.auth.uid in request.resource.data.participantsMap)
        );
      }

      allow read:   if isAdmin() || (signedIn() && isChatParticipant(chatId));
      allow create: if isAdmin() || (signedIn() && isNewChatParticipant());

      // 업데이트: 허용 키만 변경 + participants/participantsMap 절대 수정 금지
      allow update: if isAdmin() || (
        signedIn() &&
        isChatParticipant(chatId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'lastMessage','lastMessageAt','lastUpdated','updatedAt',
          'unreadCount','lastSeenAt','lastMessageId','lastMessageType','lastSender',
          'hidden','hiddenAt','blockedBy','left','leftAt','status'
        ]) &&
        !request.resource.data.diff(resource.data).changedKeys().hasAny(['participants','participantsMap']) &&
        onlySelfMapMutations()
      );

      allow delete: if isAdmin() || (signedIn() && isChatParticipant(chatId));

      // ── 맵 필드 보조 함수: 내 uid 서브키만 변경 가능
      function mapBefore(field) {
        return (field in resource.data && resource.data[field] is map) ? resource.data[field] : {};
      }
      function mapAfter(field) {
        return (field in request.resource.data && request.resource.data[field] is map) ? request.resource.data[field] : {};
      }
      function onlySelfMapChange(field) {
        let before = mapBefore(field);
        let after  = mapAfter(field);
        let diff   = after.diff(before);
        let me = request.auth.uid;
        return diff.changedKeys().hasOnly([me]) &&
               diff.addedKeys().hasOnly([me]) &&
               diff.removedKeys().hasOnly([me]);
      }
      function onlySelfMapMutations() {
        return onlySelfMapChange('unreadCount') &&
               onlySelfMapChange('lastSeenAt')  &&
               onlySelfMapChange('hidden')      &&
               onlySelfMapChange('hiddenAt')    &&
               onlySelfMapChange('blockedBy')   &&
               onlySelfMapChange('left')        &&
               onlySelfMapChange('leftAt');
      }

      match /messages/{messageId} {
        allow read: if isAdmin() || (signedIn() && isChatParticipant(chatId));
        allow create: if isAdmin() || (
          signedIn() && isChatParticipant(chatId) &&
          request.resource.data.sender == request.auth.uid
        );
        allow update: if isAdmin() || (
          signedIn() && isChatParticipant(chatId) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy'])
        );
        allow delete: if isAdmin() || (
          signedIn() && isChatParticipant(chatId) && resource.data.sender == request.auth.uid
        );
      }

      match /typing/{uid} {
        allow read: if isAdmin() || (signedIn() && isChatParticipant(chatId));
        allow create, update: if isAdmin() || (
          signedIn() &&
          isChatParticipant(chatId) &&
          uid == request.auth.uid &&
          request.resource.data.keys().hasOnly(['uid','isTyping','updatedAt']) &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.isTyping is bool
        );
        allow delete: if isAdmin() || (signedIn() && isChatParticipant(chatId) && uid == request.auth.uid);
      }
    }

    /* 롤업 뷰: 읽기만 허용 (Functions는 Admin 권한으로 무시) */
    match /chatMeta/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }
    match /chatSummaries/{uid}/threads/{chatId} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    /* 사용자별 알림 */
    match /notifications/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin() || isOwner(uid);
    }
    match /notifications/{uid}/items/{docId} {
      allow get, list: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isAdmin() || (
        isOwner(uid) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['read','readAt']) &&
        (request.resource.data.read is bool)
      );
      allow delete: if false;
    }

    /* 전역 알림(옵션) */
    match /globalNotifications/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    /* ───────── goldExchanges ───────── */
    match /goldExchanges/{id} {
      allow read:   if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /goldExchangeReviews/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    /* ───────── transactionReviews ───────── */
    match /transactionReviews/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    /* ───────── orders / transactions ───────── */
    function isMineCreate() {
      return request.resource.data.userId == request.auth.uid ||
             request.resource.data.buyerId == request.auth.uid ||
             request.resource.data.sellerId == request.auth.uid;
    }
    function isMineExisting() {
      return resource.data.userId == request.auth.uid ||
             resource.data.buyerId == request.auth.uid ||
             resource.data.sellerId == request.auth.uid;
    }
    match /orders/{id} {
      allow read, write: if isAdmin() ||
        (signedIn() &&
          ((request.method == 'create' && isMineCreate()) ||
           (request.method != 'create' && isMineExisting())));
    }
    match /transactions/{id} {
      allow read, write: if isAdmin() ||
        (signedIn() &&
          ((request.method == 'create' && isMineCreate()) ||
           (request.method != 'create' && isMineExisting())));
    }
    match /{path=**}/orders/{id} {
      allow read, write: if isAdmin() ||
        (signedIn() &&
          ((request.method == 'create' && isMineCreate()) ||
           (request.method != 'create' && isMineExisting())));
    }
    match /{path=**}/transactions/{id} {
      allow read, write: if isAdmin() ||
        (signedIn() &&
          ((request.method == 'create' && isMineCreate()) ||
           (request.method != 'create' && isMineExisting())));
    }

    /* 기본: 나머지 읽기는 로그인 필요 */
    match /{document=**} {
      allow read: if signedIn();
    }
  }
}
