            <Actions>
              {s.google && (
                <Button href={s.google} target="_blank" rel="noreferrer">
                  Google 지도
                </Button>
              )}
              {s.naver && (
                <Outline href={s.naver}  target="_blank" rel="noreferrer">
                  네이버 지도
                </Outline>
              )}
              {telMobile && (
                <Button href={telMobile} aria-label={`${s.name} 모바일로 전화하기`}>
                  모바일로 전화
