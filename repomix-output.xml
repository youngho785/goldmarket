  .skip-link:focus {
    transform: translateY(8px);
    outline: 2px solid ${({ theme }) => theme.colors?.background || "#fff"};
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .skip-link { transition: none; }
  }

  @media (prefers-contrast: more) {
    .skip-link {
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }
  }
`;

