const DT = styled.dt` color: #4b5563; font-weight: 700; `;
const DD = styled.dd` margin: 0; color: #111827; `;

const ButtonGroup = styled.div` margin-top: 15px; display: flex; gap: 10px; `;
const Button = styled.button`
