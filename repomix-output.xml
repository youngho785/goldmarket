    `}
`;

const NavItem = styled(NavLink)`
  flex: 1;
  text-align: center;
  position: relative;
  font-size: 0.75rem;
  color: ${({ $active, theme }) =>
    $active ? theme.colors.primary : theme.colors.textSecondary};
