            <Row>
              <strong>연락처</strong>
              {s.phone && telStore ? (
                <TelLink href={telStore} aria-label={`${s.name} 매장 전화하기`}>
                  {s.phone}
                </TelLink>
              ) : (
                s.phone || "-"
              )}
              {s.mobile && telMobile && (
                <>
                  {" · "}
                  <TelLink href={telMobile} aria-label={`${s.name} 모바일로 전화하기`}>
                    {s.mobile}
                  </TelLink>
                </>
              )}
