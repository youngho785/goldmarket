  ],
};
/** 잔여 조합용: 모든 규격(오름차순) */
const ALL_DENOMS = [...BAR_GROUPS.grams, ...BAR_GROUPS.don].sort((a, b) => a.grams - b.grams);

/* ── 제품 옵션 ───────────────────────── */
/** ⚠️ value 문자열은 DEFAULT_PURITY 키와 "완전히 동일"해야 합니다. */
const PRODUCT_OPTIONS = [
