  text-align: center;
  margin-bottom: 16px;
  color: ${({ theme }) => theme.colors.primary || "#333"};
`;
const NoticeBox = styled.div`
  background: #fffbeb;
  border: 1px solid #fde68a;
  color: #92400e;
  border-radius: 8px;
