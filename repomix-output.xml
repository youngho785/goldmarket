  useEffect(() => {
    const fetchFn = activeTab === "notice" ? fetchNotices : fetchInquiries;
    fetchFn()
      .then(setPosts)
      .catch((err) => {
        console.error("게시글 불러오기 오류:", err);
        alert("게시글을 불러오는 중 오류가 발생했습니다.");
